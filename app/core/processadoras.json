{
  "processadoras": {
    "consigfacil": {
      "auth_type": "certificate",
      "url_template": "https://www.faciltecnologia.com.br/consigfacil/{slug}/validar_certificado_cliente.php",
      "uses_chrome_channel": true
    },
    "safeconsig": {
      "auth_type": "login_password",
      "uses_chrome_channel": true
    },
    "consigup": {
      "auth_type": "login_password",
      "uses_chrome_channel": false,
      "selectors": {
        "username": { "type": "role", "role": "textbox", "name": "Usuário" },
        "password": { "type": "role", "role": "textbox", "name": "Senha" },
        "submit":   { "type": "role", "role": "button",  "name": "Entrar" }
      }
    },
    "consigi": {
      "auth_type": "login_password",
      "uses_chrome_channel": false,
      "selectors": {
        "username": { "type": "css", "value": "#username" },
        "password": { "type": "css", "value": "#password" },
        "submit":   { "type": "css", "value": "button:has-text('Entrar'),button[type='submit']" }
      }
    },
    "konexia": {
      "auth_type": "login_password",
      "uses_chrome_channel": false,
      "selectors": {
        "username": { "type": "css", "value": "#username" },
        "password": { "type": "css", "value": "#password" },
        "submit":   { "type": "css", "value": "button:has-text('Entrar'),button[type='submit']" }
      }
    },
    "pbconsig": {
      "auth_type": "login_password",
      "uses_chrome_channel": false,
      "selectors": {
        "username": { "type": "css", "value": "#username" },
        "password": { "type": "css", "value": "#password" },
        "submit":   { "type": "css", "value": "#kc-login" }
      }
    },
    "proconsig": {
      "auth_type": "login_password",
      "uses_chrome_channel": false,
      "selectors": {
        "username": { "type": "css", "value": "#cpf" },
        "password": { "type": "css", "value": "input[name='senha']" },
        "submit":   { "type": "css", "value": "button[type='submit']" }
      }
    },
    "consiglog": {
      "auth_type": "two_step",
      "uses_chrome_channel": false,
      "selectors": {
        "step1_username": { "type": "css", "value": "#txtLogin" },
        "step1_submit":   { "type": "css", "value": "#Entrar" },
        "step2_password": { "type": "css", "value": "#txtSenha" },
        "step2_submit":   { "type": "css", "value": "#Entrar" }
      }
    },
    "fasitec": {
      "auth_type": "blur_reveal",
      "uses_chrome_channel": false,
      "selectors": {
        "username": { "type": "css", "value": "#txtLogin" },
        "password": { "type": "css", "value": "#txtSenha" },
        "submit":   { "type": "css", "value": "#cmdUISubmit" }
      }
    },
    "digitalconsig": {
      "auth_type": "login_password",
      "uses_chrome_channel": false,
      "selectors": {
        "username": { "type": "css", "value": "#txtLogin" },
        "password": { "type": "css", "value": "#txtSenha" },
        "submit":   { "type": "css", "value": "#Entrar" }
      }
    },
    "consignet": {
      "auth_type": "two_step",
      "uses_chrome_channel": false,
      "selectors": {
        "step1_username": { "type": "css", "value": "#login-username" },
        "step1_submit":   { "type": "css", "value": "#btn-continue" },
        "step2_password": { "type": "css", "value": "#login-password" },
        "step2_submit":   { "type": "css", "value": "[id='btn-log in']" }
      }
    }
  },
